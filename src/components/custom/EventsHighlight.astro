---
// src/pages/index.astro
import { pb } from "../../lib/pocketbase";
import EventHightlightComponent from "../events/EventHighlightComponent";
import type { EventItem } from "../events/types";
import { sectionVariants } from "../../styles/style-mapping";

const now = new Date().toISOString();
const locale = Astro.currentLocale == "de" ? "de" : "en";

const translations = {
  de: {
    button_text: "Alle Ansehen",
    header: "Nächste Events",
  },
  en: {
    button_text: "See More",
    header: "Next Events",
  },
};

const eventFilter = [
  'date != ""',
  `date >= "${now}"`,
  '(location != "" || eventUrl != "")',
].join(" && ");

const events = await pb.collection<EventItem>("events").getList(1, 3, {
  filter: eventFilter,
});

// Calculate standard CVA layout wrapper classes for the event section below
const sectionClasses = sectionVariants({ alignment: "left", size: "full" });
---

<!-- Translated .spread: layout container -->
<div class="flex flex-wrap items-center justify-between gap-5 w-full">
  
  <!-- Translated h1 element with 4-point text stroke simulation -->
  <h1 class="font-display text-primary [text-shadow:-1.5px_-1.5px_0_var(--color-bg),1.5px_-1.5px_0_var(--color-bg),-1.5px_1.5px_0_var(--color-bg),1.5px_1.5px_0_var(--color-bg)]">
    {translations[locale].header}
  </h1>
  
  <!-- Translated .button and .button--small modifiers -->
  <a 
    class:list={[
      "inline-block text-sm font-accent text-primary bg-transparent no-underline cursor-pointer",
      "px-3.75 py-2.5 rounded border-2 border-primary",
      "transition duration-150 ease-out",
      "hover:bg-primary hover:text-bg"
    ]} 
    href={`/${locale}/events`}
  > 
    {translations[locale].button_text}
  </a>
</div>

<!-- Wrapped in a section component using your design system's variant properties -->
<section class:list={[sectionClasses, "mt-5"]}>
  <EventHightlightComponent events={events.items} locale={locale} />
</section>