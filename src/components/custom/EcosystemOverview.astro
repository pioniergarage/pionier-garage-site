---
const startups_rounded = 60;
const active_members = 45;
const years_of_experience = 18;

import { localized } from "../../utils/utils";

const locale = Astro.currentLocale === "de" ? "de" : "en";
const numberLocale = locale === "de" ? "de-DE" : "en-US";

const translations = {
  de: {
    activeMembers: "Aktive Mitglieder",
    startups: "Startups",
    years: "Jahre Erfahrung",
  },
  en: {
    activeMembers: "Active Members",
    startups: "Startups",
    years: "Years of Experience",
  },
} as const;

const labels = translations[locale];
---

<div
  class="w-full p-10 flex justify-items-space-between items-center text-center"
  data-count-locale={numberLocale}
>
  <div class="w-full group block">
    <h3 class="font-serif">
      {labels.startups}
    </h3>
    <h1
      class="font-serif text-[60px] leading-16.25 p-0 m-0 max-w-full wrap-anywhere text-balance"
      data-count-up
      data-count-target={startups_rounded}
      data-count-suffix="+"
      aria-label={`${new Intl.NumberFormat(numberLocale).format(startups_rounded)}+`}
    >
      {startups_rounded}+
    </h1>
  </div>

  <div class="bg-white w-1 h-full opacity-50"></div>

  <div class="w-full group block">
    <h3 class="font-serif">
      {labels.years}
    </h3>
    <h1
      class="font-serif text-[60px] leading-16.25 p-0 m-0 max-w-full wrap-anywhere text-balance"
      data-count-up
      data-count-target={years_of_experience}
      data-count-suffix=""
      aria-label={new Intl.NumberFormat(numberLocale).format(years_of_experience)}
    >
      {years_of_experience}
    </h1>
  </div>

  <div class="bg-white w-1 h-full opacity-50"></div>

  <div class="w-full group block">
    <h3 class="font-serif">
      {labels.activeMembers}
    </h3>
    <h1
      class="font-serif text-[60px] leading-16.25 p-0 m-0 max-w-full wrap-anywhere text-balance"
      data-count-up
      data-count-target={active_members}
      data-count-suffix="+"
      aria-label={`${new Intl.NumberFormat(numberLocale).format(active_members)}+`}
    >
      {active_members}
    </h1>
  </div>
</div>

<script is:inline>
  (() => {
    const counters = document.querySelectorAll("[data-count-up]");
    if (!counters.length) return;

    const localeSource = counters[0]?.closest("[data-count-locale]");
    const locale = localeSource?.getAttribute("data-count-locale") || "en-US";
    const formatter = new Intl.NumberFormat(locale);
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const renderValue = (element, value) => {
      const suffix = element.getAttribute("data-count-suffix") || "";
      element.textContent = `${formatter.format(value)}${suffix}`;
    };

    const animateCounter = (element) => {
      const target = Number(element.getAttribute("data-count-target") || "0");

      if (prefersReducedMotion) {
        renderValue(element, target);
        return;
      }

      const duration = 1400;
      const startTime = performance.now();

      renderValue(element, 0);

      const tick = (now) => {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const currentValue = Math.round(target * eased);

        renderValue(element, currentValue);

        if (progress < 1) {
          requestAnimationFrame(tick);
        }
      };

      requestAnimationFrame(tick);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          animateCounter(entry.target);
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.35 },
    );

    counters.forEach((counter) => observer.observe(counter));
  })();
</script>
