---
// src/pages/index.astro
import '../../styles/startup-page.css';
import { pb } from "../../lib/pocketbase";
import StartupsExplorer from "../startups/Startups";
import type { StartupItem } from "../startups/types";
const locale = Astro.currentLocale == "de" ? "de" : "en";

const startupFilter = [
  'shortDescription != ""',
  'headerImageUrl != ""',
  'logoUrl != ""',
  'stage != ""',
  'industry != ""',
  'marketModel != ""',
].join(" || ");

const startups = await pb.collection<StartupItem>("startups").getFullList({
  filter: startupFilter,
});
---

<div class="startups-block__surface">
  <StartupsExplorer startups={startups} locale={locale} client:load />
</div>
