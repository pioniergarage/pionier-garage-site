---
const languages = [
  { code: "en", label: "English" },
  { code: "de", label: "Deutsch" },
];

const currentPathSegments = Astro.url.pathname.split("/").filter(Boolean);
const currentLangCode = languages.some(
  (item) => item.code === currentPathSegments[0],
)
  ? currentPathSegments[0]
  : languages[0].code;

const selected =
  languages.find((lang) => lang.code === currentLangCode) || languages[0];

const getLocalizedUrl = (langCode: string) => {
  const url = new URL(Astro.url);
  const pathSegments = url.pathname.split("/").filter(Boolean);

  if (languages.some((item) => item.code === pathSegments[0])) {
    pathSegments[0] = langCode;
  } else {
    pathSegments.unshift(langCode);
  }

  url.pathname = `/${pathSegments.join("/")}`;
  return `${url.pathname}${url.search}${url.hash}`;
};
---

<language-toggle>
  <button
    type="button"
    aria-expanded="false"
    aria-haspopup="listbox"
    class="trigger"
  >
    <span class="label">{selected.code}</span>
    <!-- <span class="chevron" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
    </span> -->
  </button>

  <div class="menu" role="listbox" aria-label="Select language" style="display: none;">
    {
      languages.map((lang) => (
        <a
          href={getLocalizedUrl(lang.code)}
          role="option"
          aria-selected={selected.code === lang.code}
          class="option"
        >
          <span>{lang.label}</span>
          {selected.code === lang.code && (
            <span class="check" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
            </span>
          )}
        </a>
      ))
    }
  </div>
</language-toggle>

<script>
  class LanguageToggle extends HTMLElement {
    connectedCallback() {
      const button = this.querySelector("button");
      const menu = this.querySelector(".menu") as HTMLElement;

      if (!button || !menu) return;

      button.addEventListener("click", (e) => {
        e.stopPropagation();
        const isExpanded = button.getAttribute("aria-expanded") === "true";
        button.setAttribute("aria-expanded", String(!isExpanded));
        menu.style.display = isExpanded ? "none" : "block";
      });

      document.addEventListener("click", (e) => {
        if (!this.contains(e.target as Node)) {
          button.setAttribute("aria-expanded", "false");
          menu.style.display = "none";
        }
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          button.setAttribute("aria-expanded", "false");
          menu.style.display = "none";
        }
      });
    }
  }

  customElements.define("language-toggle", LanguageToggle);
</script>

<style>
  /* Custom element wrapper: Establishes a positioning context for the absolute menu */
  language-toggle {
    position: relative;
    display: inline-block;
    isolation: isolate;
  }

  /* Main toggle button: Resets default button styling and aligns contents */
  .trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 5px;
    padding: 0;
    border: none;
    background: none;
    color: var(--text);
    font-size: 1.9rem;
    cursor: pointer;
    transition: var(--transition);
  }

  .trigger:hover {
    opacity: 0.7;
  }

  .trigger:focus-visible {
    outline: 3px solid rgba(255, 255, 255, 0.45);
    outline-offset: 3px;
  }

  /* Current language text: Applies display font and shadow */
  .label {
    font-size: initial;
    font-family: var(--font-serif);
    text-transform: uppercase;
    text-shadow: 0px 0px 6px rgba(0, 0, 0, 0.5);
  }

  /* Dropdown arrow: Handles the 180-degree rotation when expanded */
  .chevron {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: var(--text);
    transition: transform 180ms ease;
  }

  .trigger[aria-expanded="true"] .chevron {
    transform: rotate(180deg);
  }

  /* Dropdown container: Uses absolute positioning, grid gap for items, and glassmorphism */
  .menu {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    z-index: 9;
    min-width: 200px;
    display: grid;
    gap: 2px;
    padding: 2px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--border-radius);
    background: rgba(14, 14, 14, 0.58);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    box-shadow: 0 24px 48px rgba(7, 17, 38, 0.24);
    overflow: hidden;
  }

  /* Individual language link: Removes default anchor styling and adds hover effects */
  .option {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 14px 16px;
    border: 0;
    border-radius: var(--border-radius);
    background: none;
    color: var(--text);
    font-family: var(--font-serif);
    font-size: 1.1rem;
    text-align: left;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 150ms ease;
  }

  .option:hover,
  .option:focus-visible {
    outline: none;
    opacity: 0.9;
  }

  /* Active language checkmark */
  .check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: var(--text);
  }

  /* Mobile overrides: Adjusts sizing and spacing for smaller screens */
  @media (max-width: 720px) {
    language-toggle {
      width: auto;
    }

    .trigger {
      font-size: initial; /* Fallback if 1.9rem is too large for mobile */
    }

    .menu {
      left: 0; /** Align left on small screens */
      min-width: 150px;
    }

    .option {
      padding: 10px 15px;
    }
  }

  @media (max-width: 820px) {
    .label {
      padding: 0;
      font-size: 1.9rem;
      line-height: 1.15;
    }
  }
</style>