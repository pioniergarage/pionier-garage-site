---
import { sectionVariants } from "../../styles/style-mapping";
import { twMerge } from "tailwind-merge";
import type { BlockProps } from "../types/types";

type Props = BlockProps<"section">;

const { header, body, style } = Astro.props;
---

<section class={sectionVariants({ alignment: style.alignment, size: style.size })}>
  <div class={style.className}>
    <h1>{header}</h1>
    {/* .margin-top-sm was 10px. Tailwind's mt-2.5 maps exactly to 10px (0.625rem). */}
    {body && <p class="mt-2.5">{body}</p>}
  </div>
</section>