---
import type { BlockProps } from "../types/types";
import { sectionVariants } from "../../styles/style-mapping";

type Props = BlockProps<"steps">;

const { items = [], style } = Astro.props;

const sectionClasses = sectionVariants({
  alignment: style?.alignment,
  size: style?.size,
  className: style?.className,
});
---

<section class={sectionClasses}>
  <div class="grid w-full grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
    {
      items.map((item, index) => (
        <div class="flex min-w-0 flex-col gap-3 rounded border border-stroke p-6">
          <h3 class="m-0 text-center font-display text-2xl leading-tight text-white wrap-break-word">
            {index + 1}. {item.title}
          </h3>
          {item.description && (
            <p class="m-0 font-accent leading-relaxed text-primary-muted">
              {item.description}
            </p>
          )}
        </div>
      ))
    }
  </div>
</section>
