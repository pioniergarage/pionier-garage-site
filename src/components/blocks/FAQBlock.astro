---
import type { BlockProps } from "../types/types";

type Props = BlockProps<"faq">;

const { items, style } = Astro.props;
---

<section class={`${style.alignment} ${style.size}`}>
  {
    items?.map((item) => (
      <details class={`faq-details ${style.className ?? ""}`}>
        <summary class="faq-summary">
          <h2>{item.question}</h2>
          <svg 
            class="faq-icon" 
            xmlns="http://www.w3.org/2000/svg" 
            width="24" 
            height="24" 
            viewBox="0 0 24 24" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="2" 
            stroke-linecap="round" 
            stroke-linejoin="round"
          >
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </summary>
        
        <div class="content">{item.answer}</div>
      </details>
    ))
  }
</section>

<style>
  /* Hide the default HTML arrow */
  .faq-summary {
    list-style: none; /* Modern browsers */
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    padding: 1rem 0;
  }

  .faq-summary::-webkit-details-marker {
    display: none; /* Safari */
  }

  /* Style the H3 to look correct inside the summary */
  .faq-summary h3 {
    margin: 0;
    font-size: 1.5rem; /* Standard h3 sizing */
    font-weight: 600;
    line-height: 1.3;
  }

  /* Style the custom SVG arrow */
  .faq-icon {
    flex-shrink: 0; /* Prevents the arrow from squishing if the headline is very long */
    margin-left: 1.5rem;
    transition: transform 0.2s ease-in-out;
  }

  /* Rotate arrow when the details block is expanded */
  details[open] .faq-icon {
    transform: rotate(180deg);
  }

  details[open]{
    padding-bottom: 1em;
  }

  .content {
    padding-left: 0;
    line-height: 1.6;
    color: var(--text-muted, #a1a1aa);
    animation: pop-in 180ms ease-in;
    display:none;
    white-space: pre-line;
  }

  details[open] .content {
    display:inline;
    margin-bottom: 4px;
  }
  
  .faq-details {
    border-bottom: 1px solid var(--stroke, #27272a);
  }
</style>
