---
import { twMerge } from "tailwind-merge";
import type { BlockProps } from "../types/types";
import { sectionVariants } from "../../styles/style-mapping";


type Props = BlockProps<"faq">;

const { items, style } = Astro.props;

const sectionClasses = twMerge(
  sectionVariants({ alignment: style.alignment, size: style.size }),
  style?.className
);
---

<section class={sectionClasses}>
  {
    items?.map((item) => (
      <details class="group border-b border-stroke open:pb-4">
        
        {/* list-none and the webkit pseudo-selector hide the native browser arrow */}
        <summary class="flex cursor-pointer list-none items-center justify-between py-4 [&::-webkit-details-marker]:hidden">
          <h2 class="m-0 text-2xl font-semibold leading-[1.3]">
            {item.question}
          </h2>
          
          {/* group-open applies styles based on the parent details element's state */}
          <svg 
            class="ml-6 shrink-0 transition-transform duration-200 ease-in-out group-open:rotate-180" 
            xmlns="http://www.w3.org/2000/svg" 
            width="24" 
            height="24" 
            viewBox="0 0 24 24" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="2" 
            stroke-linecap="round" 
            stroke-linejoin="round"
          >
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </summary>
        
        {/* 
          Native <details> handles the display toggle intrinsically. 
          We use group-open to apply margins and trigger your custom animation.
        */}
        <div class="whitespace-pre-line leading-[1.6] text-primary-muted group-open:animate-[drop-and-fade_180ms_ease-in] group-open:mb-1">
          {item.answer}
        </div>
        
      </details>
    ))
  }
</section>