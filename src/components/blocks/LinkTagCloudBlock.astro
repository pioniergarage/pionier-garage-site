---
import { twMerge } from "tailwind-merge";
import { localized } from "../../utils/utils";
import { sectionVariants } from "../../styles/style-mapping";
import type { BlockProps } from "../types/types";

type Props = BlockProps<"tag-cloud">;

const { title, tags, style } = Astro.props;

// 1. Apply the CVA configuration to the outer section
const sectionClasses = sectionVariants({
  alignment: style?.alignment,
  size: style?.size,
  className:style?.className
});

// 2. Handle the inner wrapper's custom layout and CMS fallback
const innerWrapperClasses = twMerge(
  "flex flex-col justify-start gap-2", // Translated from "l-stack l-stack--sm"
  style.className
);
---

<section class={sectionClasses}>
  <div class={innerWrapperClasses}>
    {/* Translated .margin-left-md (20px) to ml-5 */}
    <h2 class="ml-5">{title}</h2>
    
    {/* Translated inline styles to Tailwind utilities (gap: 10px -> gap-2.5) */}
    <div class="flex flex-wrap items-center gap-2.5">
      {
        tags?.map((tag) => (
          <a 
            class="inline-block px-5 py-3.75 text-base font-inherit text-primary bg-transparent border-2 border-primary rounded transition duration-150 ease-out cursor-pointer hover:bg-primary hover:text-bg"
            href={localized(tag.link ?? "", Astro.currentLocale, ["EN", "DE"])}
          >
            {tag.text}
          </a>
        ))
      }
    </div>
  </div>
</section>