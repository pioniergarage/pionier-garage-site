---
import type { BlockProps } from "../types/types";
import { sectionVariants } from "../../styles/style-mapping";
import { twMerge } from "tailwind-merge";

// Assuming size is a string like "24px", "4rem", etc. passed from your CMS
type Props = BlockProps<"spacer"> & {
  size: string;
};

const { style, size } = Astro.props;

// Merge base section variants with incoming className overrides.
// We explicitly pass 'full' as the size variant so it spans 100% width, 
// keeping it decoupled from the height calculation.
const containerClasses = twMerge(
  sectionVariants({ alignment: style.alignment, size: "full",className:style.className }),
  "inline-block align-middle h-[var(--spacer-height)]"
);
---

<section
  class={containerClasses}
  style={{ "--spacer-height": size }}
>
</section>