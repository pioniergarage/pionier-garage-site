---
import { Image } from "astro:assets";
import type { BlockProps } from "../types/types";
import { sectionVariants } from "../../styles/style-mapping";

type Props = BlockProps<"testimonials">;

const { items = [], style } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,webp,avif,svg}",
);

for (const item of items) {
  const image = item.image;
  if (image && !images[image]) {
    throw new Error(
      `"${image}" does not exist. Make sure the path is correct and matches the glob pattern.`,
    );
  }
}

const sectionClasses = sectionVariants({
  alignment: style?.alignment,
  size: style?.size,
  className: style?.className,
});
---

<section class={sectionClasses}>
  <div class="flex gap-6 flex-wrap justify-between">
    {
      items.map((item) => (
        <figure class="m-0 flex grow basis-full flex-col justify-between gap-6 rounded bg-black border border-stroke p-5 md:basis-[calc(30%-0.75rem)] md:max-w-120">
          {item.quote && (
            <blockquote class="m-0 leading-relaxed">
              {item.quote}
            </blockquote>
          )}

          <figcaption class="flex items-center gap-3">
            {item.image && (
              <div class="h-12 w-12 shrink-0 overflow-hidden rounded-full bg-stroke">
                <Image
                  src={images[item.image]()}
                  alt={item.name ?? ""}
                  width={96}
                  height={96}
                  class="m-0 h-full w-full object-cover p-0"
                />
              </div>
            )}

            {(item.name || item.role) && (
              <div class="flex flex-col leading-tight">
                {item.name && (
                  <span class="text-primary">{item.name}</span>
                )}
                {item.role && (
                  <span class="text-sm text-primary-muted">{item.role}</span>
                )}
              </div>
            )}
          </figcaption>
        </figure>
      ))
    }
  </div>
</section>
