---
import { Image } from "astro:assets";
import type { BlockProps } from "../types/types";
import { sectionVariants } from "../../styles/style-mapping";

type Props = BlockProps<"highlight-cards">;

const { items = [], style } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,webp,avif,svg}",
);

for (const item of items) {
  const image = item.image;
  if (image && !images[image]) {
    throw new Error(
      `"${image}" does not exist. Make sure the path is correct and matches the glob pattern.`,
    );
  }
}

// Up to 3 cards fill the row; beyond that they become a swipeable carousel.
const isCarousel = items.length > 3;

const sectionClasses = sectionVariants({
  alignment: style?.alignment,
  size: style?.size,
  className: style?.className,
});
---

<section class={sectionClasses}>
  <div class="highlight-cards relative w-full">
    <div
      class:list={[
        "highlight-track gap-5",
        isCarousel
          ? "flex snap-x snap-mandatory overflow-x-auto scroll-smooth pb-2 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
          : "flex flex-col md:flex-row",
      ]}
    >
      {
        items.map((item) => (
          <article
            class:list={[
              "highlight-card relative aspect-2/3 overflow-hidden rounded-lg",
              isCarousel
                ? "shrink-0 snap-start basis-[85%] sm:basis-[47%] lg:basis-[31.7%]"
                : "flex-1",
            ]}
          >
            {item.image && (
              <Image
                src={images[item.image]()}
                alt={item.title ?? ""}
                widths={[400, 600, 800]}
                sizes="(max-width: 768px) 85vw, 33vw"
                class="absolute inset-0 m-0 h-full w-full object-cover p-0"
              />
            )}

            <div class="absolute inset-0 bg-linear-to-tr from-black/80 via-black/25 to-black/40" />

            {item.title && (
              <h3 class="absolute bottom-6 left-5 m-0 max-h-[calc(100%-3rem)] rotate-180 font-display text-4xl leading-none text-white uppercase [writing-mode:vertical-rl]">
                {item.title}
              </h3>
            )}

            {item.buttonText && (
              <a
                href={item.link || undefined}
                class="absolute right-5 bottom-6 inline-block rounded border-2 border-white/80 bg-black/20 px-5 py-3 font-accent text-base text-white backdrop-blur-xs transition duration-150 ease-in hover:bg-white hover:text-bg"
              >
                {item.buttonText}
              </a>
            )}
          </article>
        ))
      }
    </div>

    {
      isCarousel && (
        <>
          <button
            type="button"
            aria-label="Previous"
            class="highlight-prev absolute top-1/2 left-2 z-10 hidden h-11 w-11 -translate-y-1/2 place-items-center rounded-full border-2 border-white/60 bg-black/50 text-white backdrop-blur-xs transition hover:bg-black/80 disabled:cursor-default disabled:opacity-30 md:grid"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
          </button>
          <button
            type="button"
            aria-label="Next"
            class="highlight-next absolute top-1/2 right-2 z-10 hidden h-11 w-11 -translate-y-1/2 place-items-center rounded-full border-2 border-white/60 bg-black/50 text-white backdrop-blur-xs transition hover:bg-black/80 disabled:cursor-default disabled:opacity-30 md:grid"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
          </button>
        </>
      )
    }
  </div>
</section>

<script>
  // Wires up the prev/next arrows for the carousel variant. Each click scrolls
  // the track by one card width; the arrows disable at the start/end.
  function setupHighlightCards() {
    document
      .querySelectorAll<HTMLElement>(".highlight-cards")
      .forEach((root) => {
        const track = root.querySelector<HTMLElement>(".highlight-track");
        const prev = root.querySelector<HTMLButtonElement>(".highlight-prev");
        const next = root.querySelector<HTMLButtonElement>(".highlight-next");
        if (!track || !prev || !next) return;

        const step = () => {
          const card = track.querySelector<HTMLElement>(".highlight-card");
          const gap = parseFloat(getComputedStyle(track).columnGap) || 20;
          return card ? card.getBoundingClientRect().width + gap : track.clientWidth;
        };

        const updateButtons = () => {
          const maxScroll = track.scrollWidth - track.clientWidth - 1;
          prev.disabled = track.scrollLeft <= 0;
          next.disabled = track.scrollLeft >= maxScroll;
        };

        prev.addEventListener("click", () =>
          track.scrollBy({ left: -step(), behavior: "smooth" }),
        );
        next.addEventListener("click", () =>
          track.scrollBy({ left: step(), behavior: "smooth" }),
        );
        track.addEventListener("scroll", updateButtons, { passive: true });
        window.addEventListener("resize", updateButtons);
        updateButtons();
      });
  }

  setupHighlightCards();
</script>
