---
import { twMerge } from "tailwind-merge";
import { localized, renderHeadline } from "../../utils/utils";
import type { BlockProps } from "../types/types";
import { alignmentVariants, sectionVariants } from "../../styles/style-mapping";

type Props = BlockProps<"hero">;

const { heroTagline, title, subtitle, button, style, image, titleStyle } = Astro.props;
const renderedHeadline = renderHeadline(title ?? "");
const hasImage = Boolean(image);

const sectionClasses = sectionVariants({
  alignment: style?.alignment,
  size: style?.size,
  className: style?.className,
});
const alignmentClasses = alignmentVariants[style?.alignment];
const titleAlignment = titleStyle?.alignment ?? style?.alignment ?? "center";

const titleSizeClasses = {
  small: "text-4xl md:text-5xl",
  medium: "text-5xl md:text-6xl",
  large: "text-5xl md:text-7xl lg:text-8xl",
  xlarge: "text-6xl md:text-8xl lg:text-[6rem]",
  display: "text-6xl md:text-8xl lg:text-[7.5rem]",
};

const titleColorClasses = {
  primary: "text-primary",
  background: "text-bg",
  "accent-red": "text-accent-red",
  inherit: "text-inherit",
};

const titleAlignClasses = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
};

const defaultTitleSize = hasImage ? "display" : "large";
const defaultTitleColor = hasImage ? "accent-red" : "inherit";

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,webp,avif,svg}",
);

if (hasImage && !images[image]) {
  throw new Error(
    `"${image}" does not exist. Make sure the path is correct and matches the glob pattern.`,
  );
}
const imageModule = hasImage ? await images[image]() : undefined;
const backgroundUrl = imageModule?.default.src;
---

<section class={sectionClasses}>
  <div
    class={twMerge(
      "w-full px-4",
      "flex flex-col",
      alignmentClasses,
      hasImage
        ? "bg-cover bg-center mb-8 gap-4 h-auto md:justify-end md:gap-0 md:h-[80vh]"
        : "min-h-[70vh] justify-center",
    )}
    style={backgroundUrl && {
      backgroundImage: `
        linear-gradient(to bottom, transparent 50%, var(--color-bg) 100%), 
        linear-gradient(to top, transparent 50%, var(--color-bg) 100%),
        radial-gradient(circle at center, transparent 40%, var(--color-bg) 100%), 
        url(${backgroundUrl})
      `,
    }}
  >
    {heroTagline && <h3 class="font-accent text-xl">{heroTagline}</h3>}
    <h1
      class={twMerge(
        "font-display leading-none text-balance wrap-break-word max-w-full",
        titleSizeClasses[titleStyle?.size ?? defaultTitleSize],
        titleColorClasses[titleStyle?.color ?? defaultTitleColor],
        titleAlignClasses[titleAlignment],
        "[&_.outlined]:text-bg [&_.outlined]:[text-shadow:-2px_-2px_0_var(--color-accent-red),2px_-2px_0_var(--color-accent-red),-2px_2px_0_var(--color-accent-red),2px_2px_0_var(--color-accent-red)]",
        titleStyle?.className,
      )}
      set:html={renderedHeadline}
    />

    <h2 class="m-0 p-0 max-w-[30ch] md:max-w-[50ch] text-center">{subtitle}</h2>

    {
      button && (
        <a
          class={twMerge(
            // Translated .button-accent and .margin-top-lg
            "mt-10 inline-block px-5 py-3.75 font-inherit text-accent-red bg-transparent",
            "border-2 border-accent-red rounded cursor-pointer",
            "transition duration-150 ease-out hover:bg-accent-red hover:text-bg",
            "animate-glow-accent",
          )}
          href={localized(button.link, Astro.currentLocale, ["en", "de"])}
        >
          {button.text}
        </a>
      )
    }
  </div>
</section>
