---
import { twMerge } from "tailwind-merge";
import { localized, renderHeadline } from "../../utils/utils";
import { sectionVariants } from "../../utils/style-mapping";
import type { BlockProps } from "../types/types";

type Props = BlockProps<"hero">;

const { heroTagline, title, subtitle, button, style } = Astro.props;
const renderedHeadline = renderHeadline(title ?? "");

// Apply the imported CVA variants to the outer wrapper
const sectionClasses = sectionVariants({ alignment: style?.alignment, size: style?.size });
---

<section class={sectionClasses}>
  <div class={twMerge(
    // Mobile (Default): auto height, centered layout, explicit gap
    "flex flex-col items-center justify-center gap-4 h-auto min-h-[calc(100svh-75px)]",
    // Desktop: 80vh height, bottom-aligned, no gap (elements control their own spacing)
    "md:justify-end md:gap-0 md:h-[80vh] md:min-h-100",
    style?.className
  )}>
    {heroTagline && <h3 class="font-serif font-normal">{heroTagline}</h3>}
    
    <h1 
      class={twMerge(
        // Base typography translated from global.css .title
        "font-display text-accent-red text-center text-balance wrap-break-word max-w-full",
        // Responsive sizing translated from the media query
        "text-[clamp(2.75rem,12vw,3.75rem)] leading-none",
        "md:text-[60px] md:leading-16.25",
        // Targets the HTML injected by renderHeadline()
        // Note: Assumes your @theme setup mapped the CSS variable to --color-accent-red
        "[&_.outlined]:text-bg [&_.outlined]:[text-shadow:-2px_-2px_0_var(--color-accent-red),2px_-2px_0_var(--color-accent-red),-2px_2px_0_var(--color-accent-red),2px_2px_0_var(--color-accent-red)]"
      )} 
      set:html={renderedHeadline} 
    />
    
    {/* See note below regarding the max-width logic */}
    <h2 class="m-0 p-0 max-w-[30ch] md:max-w-[50ch] text-center">{subtitle}</h2>

    {
      button && (
        <a
          class={twMerge(
            // Translated .button-accent and .margin-top-lg
            "mt-10 inline-block px-5 py-3.75 font-inherit text-accent-red bg-transparent",
            "border-2 border-accent-red rounded cursor-pointer",
            "transition duration-150 ease-out hover:bg-accent-red hover:text-bg",
            "animate-glow-accent"
          )}
          href={localized(button.link, Astro.currentLocale, ["en", "de"])}
        >
          {button.text}
        </a>
      )
    }
  </div>
</section>