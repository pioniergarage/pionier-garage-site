---
import { Image } from "astro:assets";
import { twMerge } from "tailwind-merge";
import { sectionVariants } from "../../styles/style-mapping";
import type { BlockProps } from "../types/types";

type Props = BlockProps<"image"> & { alt?: string };

const { image, style, size, alt = "" } = Astro.props;

const widths = {
  small: 400,
  medium: 800,
  large: 1200,
};

// Added keyof typeof to prevent TypeScript indexing errors
const selectedWidth = size ? widths[size as keyof typeof widths] : widths.large;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,webp,avif}",
);

if (image && !images[image]) {
  throw new Error(
    `"${image}" does not exist. Make sure the path is correct and matches the glob pattern.`,
  );
}

// Generate the wrapper classes using your centralized CVA config
const sectionClasses = sectionVariants({
  alignment: style?.alignment,
  size: style?.size,
  className:style?.className
});
---

<section class={sectionClasses}>
  {
    image && (
      <Image
        src={images[image]()}
        width={selectedWidth}
        alt={alt}
        class={twMerge(
          "max-w-full h-auto block rounded", 
          style?.className
        )}
      />
    )
  }
</section>