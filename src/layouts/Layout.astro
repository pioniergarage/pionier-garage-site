---
import "../styles/global.css";
import { Image } from "astro:assets";
import backgroundGradient from "../assets/background_gradient_desktop.svg";
import backgroundGradientMobile from "../assets/background_gradient_mobile.svg";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

const root_anim = Astro.originPathname.length < 5 ? "appear-slowly" : "";
---

<!doctype html>
<html lang={Astro.currentLocale}>
  <head>
    <BaseHead />
  </head>
  <body>
    <div class="hero-wrapper">
      <div class="hero" id="gradient">
        <Image
          class=`hero__image hero__image--desktop ${root_anim}`
          src={backgroundGradient}
          fetchpriority="high"
          alt="background gradient"
          loading="eager"
        />
        <Image
          class=`hero__image hero__image--mobile ${root_anim}`
          src={backgroundGradientMobile}
          fetchpriority="high"
          alt="background gradient"
          loading="eager"
        />
        <div class="overlay"></div>
      </div>
    </div>

    <div class="content-wrapper">
      <Header class={root_anim} />
      <main id="main-content" class="content">
        <slot />
      </main>
      <Footer />
    </div>
  </body><script>
    const header = document.getElementById("header")!;

    window.addEventListener("scroll", () => {
      if (window.scrollY > 50) {
        header.classList.add("active");
      } else {
        header.classList.remove("active");
      }
    });
  </script>
</html>

<style>
  .hero {
    width: 100%;
    max-width: 1450px;
  }

  .hero__image {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .hero__image--mobile {
    display: none;
  }

  .hero-wrapper {
    width: 100%;
    z-index: 0;
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 576px) {
    .hero__image--mobile {
      display: block;
    }

    .hero__image--desktop {
      display: none;
    }
  }

  .hero .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    max-height: 400px;
    background: linear-gradient(
      rgba(0, 0, 0, 0.1),
      rgba(0, 0, 0, 0.7),
      rgba(0, 0, 0, 1)
    );
    backdrop-filter: blur(25px);
  }
</style>
